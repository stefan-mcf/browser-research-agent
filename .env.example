# Browser Research Agent local runtime settings
# Copy to .env for local experiments only. Do not commit real secrets.

PORT=8000

BROWSER_RESEARCH_AGENT_NO_SANDBOX=0

# Optional: where API runs write artifacts when the client omits out_dir.
# The current API default is artifacts/api-runs/<run_id> inside the container/app working directory.
ARTIFACT_ROOT=artifacts/api-runs

# No API keys are required for the deterministic local demo.
# Add provider credentials only after the relevant integration is designed and reviewed.
